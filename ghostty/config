theme = tokyonight_moon
font-family = Liga SFMono Nerd Font
font-size = 11
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true
background-opacity = .95
auto-update = download
macos-option-as-alt = true
keybind = global:cmd+§=toggle_quick_terminal
keybind = global:alt+h=goto_split:left
keybind = global:alt+j=goto_split:bottom
keybind = global:alt+k=goto_split:top
keybind = global:alt+l=goto_split:right
keybind = alt+3=text:#
